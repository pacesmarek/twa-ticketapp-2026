---
import AuthGuard from '../../components/AuthGuard.astro';
import '../../styles/app.css';
import '@sg-styles/tokens.css';
import '@sg-styles/typography.css';
import '@sg-styles/components.css';
---

<html lang="cs">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Tickety</title>
  </head>
  <body>
    <AuthGuard />

    <div class="container" style="padding-top: 4rem; padding-bottom: 4rem;">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2.4rem;">
        <h1 style="font-size: 2.4rem; margin: 0;">Tickety</h1>
        <a href="/tickets/new" class="btn btn-primary">+ Nový ticket</a>
      </div>

      <div class="card" x-data="ticketList()" x-init="loadTickets()">
        <!-- Loading state -->
        <div x-show="loading" style="padding: 2.4rem; text-align: center; color: #9ca3af;">
          Načítání ticketů...
        </div>

        <!-- Error state -->
        <div x-show="error" style="padding: 2.4rem; text-align: center; color: #b91c1c;">
          <p x-text="error"></p>
        </div>

        <!-- Tickets table -->
        <table class="table" x-show="!loading && !error">
          <thead>
            <tr>
              <th>#</th>
              <th>Název</th>
              <th>Status</th>
              <th>Priorita</th>
              <th>Přiřazeno</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <template x-for="ticket in tickets" :key="ticket.id">
              <tr>
                <td style="color: #9ca3af;" x-text="ticket.id"></td>
                <td x-text="ticket.title"></td>
                <td>
                  <span :class="`badge badge-${ticket.status}`" x-text="ticket.status"></span>
                </td>
                <td>
                  <span :class="`badge badge-${ticket.priority}`" x-text="ticket.priority"></span>
                </td>
                <td x-text="ticket.assignee"></td>
                <td style="white-space: nowrap;">
                  <a :href="`/tickets/${ticket.id}/edit`" style="margin-right: 1.2rem;">Upravit</a>
                  <button
                    class="btn"
                    style="background: #fee2e2; color: #b91c1c; padding: 0.4rem 1rem; font-size: 1.3rem;"
                    @click="deleteTicket(ticket.id)"
                  >
                    Smazat
                  </button>
                </td>
              </tr>
            </template>
          </tbody>
        </table>

        <!-- Empty state -->
        <div x-show="!loading && !error && tickets.length === 0" style="padding: 2.4rem; text-align: center; color: #9ca3af;">
          Žádné tickety. <a href="/tickets/new">Vytvořte první ticket</a>.
        </div>
      </div>

      <p style="margin-top: 2rem;"><a href="/">← Zpět</a></p>
    </div>

    <script is:inline>
      window.ticketList = function() {
        return {
          tickets: [],
          loading: true,
          error: null,

          async loadTickets() {
            try {
              this.loading = true;
              this.error = null;
              const response = await fetch('/api/tickets');
              
              if (!response.ok) {
                throw new Error('Nepodařilo se načíst tickety');
              }
              
              this.tickets = await response.json();
            } catch (err) {
              this.error = err.message;
            } finally {
              this.loading = false;
            }
          },

          async deleteTicket(id) {
            if (!confirm('Opravdu smazat tento ticket?')) {
              return;
            }

            try {
              const response = await fetch(`/api/tickets/${id}`, {
                method: 'DELETE'
              });

              if (response.ok) {
                // Reload data po smazání
                await this.loadTickets();
              } else {
                alert('Nepodařilo se smazat ticket');
              }
            } catch (err) {
              alert('Chyba při mazání: ' + err.message);
            }
          }
        };
      };
    </script>
  </body>
</html>
